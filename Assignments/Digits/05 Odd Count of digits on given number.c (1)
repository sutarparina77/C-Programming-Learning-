#include<stdio.h>
#include<conio.h>
int main()
{
  int No = 0, OddD_Cnt = 0, Dig = 0, Temp = 0;
  
  printf("\n Enter a Number:");
  scanf("%d",&No);
  
  Temp = No;
  
  if(Temp > 0 || Temp < 9)
  {
    while(Temp != 0)
    {
      Dig = Temp % 10;
      if(Dig % 2 == 1)
      {
        OddD_Cnt++;
      }
      Temp /= 10;
    }
  }
  
  printf("\n Odd Count of digi()ts of given number %d = %d", No, OddD_Cnt);
 
  getch();
  return 0;
}