#include<stdio.h>
#include<conio.h>
int main()
{
  int i = 0, j = 0, RC = 0;
  char ch = '\0';
  
  printf("\n Enter Row and Column size:");
  scanf("%d",&RC);
  
  for(i = 1; i <= RC; i++)    
  {
    for(ch = 'A', j = 1; j <= RC; j++, ch++)   
    {
      if(j == 1 || i == RC || i >= j)
      {
          printf(" %c ",ch);
      }
      else
      {
          printf("   ");
      }
    }
    printf("\n");
  }

  getch();
  return 0;
}
